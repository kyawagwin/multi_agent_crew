# OpenAI API Key for language models
OPENAI_API_KEY="your_openai_api_key_here"

# Tavily API Key for web search tool
TAVILY_API_KEY="your_tavily_api_key_here"

# MongoDB Connection String (e.g. mongodb+srv://<user>:<password>@cluster0.exmpl.mongodb.net)
MONGODB_URI="your_mongodb_connection_string_here"
MONGODB_DB_NAME="trading_db"
MONGODB_COLLECTION="stock_analysis"

# Webhook URL to send the final analysis
WEBHOOK_URL="your_webhook_url_here"
